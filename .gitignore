.coverage
.coverage.*
coverage.xml
*.cover
*.py,cover
.hypothesis/
htmlcov/
.tox/
.nox/
.cache
nosetests.xml

# Type checkers / linters
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/

# ============================================================================
# Node / TypeScript (e2e + load tests, canary scripts)
# ============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.tsbuildinfo
.npm
.eslintcache
coverage/
playwright-report/
test-results/

# ============================================================================
# Docker
# ============================================================================
*.pid
docker-compose.override.yml

# ============================================================================
# Kubernetes / Helm
# ============================================================================
charts/**/charts/        # downloaded chart dependencies
*.tgz                    # packaged charts
**/secrets.dec.yaml      # decrypted secrets (sops, etc.)
kubeconfig
*.kubeconfig

# ============================================================================
# Secrets & credentials  (defense in depth — never commit these)
# ============================================================================
*.pem
*.key
*.p12
*.pfx
*.crt
!**/templates/*.yaml     # don't ignore helm template files named *.crt-ish
.aws/
credentials
.envrc
*.secrets
secrets.auto.tfvars

# ============================================================================
# IDE / Editor
# ============================================================================
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.shared.json
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-project
*.sublime-workspace

# ============================================================================
