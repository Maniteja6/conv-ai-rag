# ============================================================================
# Terraform
# ============================================================================
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfstate.backup
crash.log
crash.*.log
*.tfvars
*.tfvars.json
!example.tfvars
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc
*.tfplan
*.tfplan.*
.terraform.lock.hcl
!.terraform.lock.hcl    # keep lock file for reproducible providers (comment out if you prefer per-env)

# ============================================================================
